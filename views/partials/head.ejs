<link rel="icon" type="image/png" sizes="64x64" href="/images/favicon-64.png">
<link rel="apple-touch-icon" href="/images/favicon-64.png">
<link rel="stylesheet" href="/fonts/fonts.css">
<link rel="stylesheet" href="/css/style.css">
